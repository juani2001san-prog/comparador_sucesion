# Copiá este archivo como  secrets.toml  (sin .example) para uso local con clave,
# o cargá esta línea en Streamlit Cloud: Settings -> Secrets.
# La app pide esta contraseña para entrar. Cambiala por la tuya.
password = "cambiame-por-una-clave-segura"

# --- Tareas y checklist (base de datos compartida en Supabase) ---
# Las dos claves salen de tu proyecto en Supabase: Settings -> API.
#   url  = "Project URL"
#   key  = "service_role" (¡es secreta, NO la compartas ni la subas al repo!)
[supabase]
url = "https://xxxxxxxxxxxx.supabase.co"
key = "pega-aca-tu-clave-service_role"

# Nombres del equipo para el selector "¿Quién sos?"
[equipo]
miembros = ["Juani", "Compañero/a"]
